<Window x:Class="DrawWallAdmin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DrawWall Admin" Height="580" Width="700"
        MinHeight="400" MinWidth="500"
        Background="#0d0b18"
        FontFamily="Consolas"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Flat button control template -->
        <ControlTemplate x:Key="FlatBtn" TargetType="Button">
            <Border x:Name="bd"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#2a1f50"/>
                    <Setter TargetName="bd" Property="BorderBrush" Value="#f0c040"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="bd" Property="Background" Value="#3d2d70"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- Default button -->
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Template"       Value="{StaticResource FlatBtn}"/>
            <Setter Property="Background"     Value="#1a1430"/>
            <Setter Property="Foreground"     Value="#f0c040"/>
            <Setter Property="BorderBrush"    Value="#7850c8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"        Value="14,7"/>
            <Setter Property="Margin"         Value="3,0"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="FontFamily"     Value="Consolas"/>
            <Setter Property="FontSize"       Value="12"/>
        </Style>

        <!-- Danger (red) button -->
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Foreground"  Value="#e74c3c"/>
            <Setter Property="BorderBrush" Value="#8b1a1a"/>
        </Style>

        <!-- Success (green) button -->
        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Foreground"  Value="#50c878"/>
            <Setter Property="BorderBrush" Value="#1a5a30"/>
        </Style>

        <!-- Shared TextBox style -->
        <Style x:Key="TBox" TargetType="TextBox">
            <Setter Property="Background"          Value="#06040e"/>
            <Setter Property="Foreground"          Value="#d0c0f0"/>
            <Setter Property="BorderBrush"         Value="#7850c8"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="Padding"             Value="6,5"/>
            <Setter Property="CaretBrush"          Value="#f0c040"/>
            <Setter Property="SelectionBrush"      Value="#7850c8"/>
            <Setter Property="FontFamily"          Value="Consolas"/>
            <Setter Property="FontSize"            Value="12"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="Auto"/>  <!-- Config -->
            <RowDefinition Height="Auto"/>  <!-- Quick commands -->
            <RowDefinition Height="Auto"/>  <!-- Export / Import -->
            <RowDefinition Height="Auto"/>  <!-- Input row -->
            <RowDefinition Height="*"/>     <!-- Output -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Title ── -->
        <TextBlock Grid.Row="0"
                   Text="DrawWall Admin"
                   Foreground="#f0c040" FontSize="20" FontWeight="Bold"
                   Margin="0,0,0,12"/>

        <!-- ── Config ── -->
        <Border Grid.Row="1"
                BorderBrush="#7850c8" BorderThickness="1"
                Padding="10,8" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="SERVER"
                           Foreground="#c8853a" FontSize="11" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="ServerBox"
                           Style="{StaticResource TBox}"
                           Text="https://drawwall-production.up.railway.app"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="KEY"
                           Foreground="#c8853a" FontSize="11" VerticalAlignment="Center"/>
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="KeyBox"
                           Style="{StaticResource TBox}"
                           Text="changeme"/>
            </Grid>
        </Border>

        <!-- ── Quick commands ── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,4">
            <Button Style="{StaticResource Btn}"       Content="STATUS"          Click="OnStatus"/>
            <Button Style="{StaticResource Btn}"       Content="USERS"           Click="OnUsers"/>
            <Button Style="{StaticResource Btn}"       Content="PIXELS"          Click="OnPixels"/>
            <Button Style="{StaticResource DangerBtn}" Content="⚠ CLEAR CANVAS"  Click="OnClear" Margin="20,0,3,0"/>
        </StackPanel>

        <!-- ── Canvas persistence ── -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Style="{StaticResource GreenBtn}" Content="⬇ EXPORT CANVAS" Click="OnExport"/>
            <Button Style="{StaticResource Btn}"      Content="⬆ IMPORT CANVAS" Click="OnImport"/>
        </StackPanel>

        <!-- ── Input + targeted commands ── -->
        <Grid Grid.Row="4" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0" x:Name="InputBox"
                     Style="{StaticResource TBox}"
                     ToolTip="Enter name/ID for Kick, or a message for Announce / Chat"
                     KeyDown="OnInputKeyDown"/>

            <Button Grid.Column="1" Style="{StaticResource DangerBtn}" Content="KICK"     Click="OnKick"     Margin="6,0,3,0"/>
            <Button Grid.Column="2" Style="{StaticResource Btn}"       Content="ANNOUNCE" Click="OnAnnounce"/>
            <Button Grid.Column="3" Style="{StaticResource GreenBtn}"  Content="CHAT"     Click="OnChat"/>
        </Grid>

        <!-- ── Output ── -->
        <Border Grid.Row="5" BorderBrush="#7850c8" BorderThickness="1">
            <TextBox x:Name="OutputBox"
                     Background="#06040e" Foreground="#c8f0a0"
                     BorderThickness="0" Padding="8"
                     IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="12"/>
        </Border>

        <!-- ── Status bar ── -->
        <Grid Grid.Row="6" Margin="0,6,0,0">
            <TextBlock x:Name="StatusBar"
                       Foreground="#604080" FontSize="10" VerticalAlignment="Center"
                       Text="Enter a name/ID to Kick, or a message to Announce/Chat · Enter key sends Chat"/>
            <Button Style="{StaticResource Btn}" Content="CLEAR LOG"
                    HorizontalAlignment="Right" Padding="10,5"
                    Click="OnClearLog"/>
        </Grid>

    </Grid>
</Window>
